# Copy this file to .env and fill in real values for local docker compose up.
# Do NOT commit .env (it is in .gitignore via the standard Node pattern).
# In production (Render, Vercel, ...), set these in the platform's env-var UI.

# --- MongoDB credentials -------------------------------------------------
# Used by docker-compose.yml for the mongodb service AND assembled into
# MONGODB_URI for the backend. Change both by changing these two lines.
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=dev-only-change-me

# --- JWT signing secret --------------------------------------------------
# 32+ random bytes. Generate with: openssl rand -hex 32
# In production, set NODE_ENV=production and provide a real JWT_SECRET --
# server.js will exit on startup if the secret is missing in production.
JWT_SECRET=dev-only-change-me-in-prod

# --- CORS allowlist ------------------------------------------------------
# Comma-separated list of allowed origins. Default in dev: localhost:3000.
# In production list the real frontend origin(s) explicitly.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Other ---------------------------------------------------------------
NODE_ENV=development
